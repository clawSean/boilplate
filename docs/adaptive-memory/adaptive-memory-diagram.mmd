  'background': '#0a0a0a',
  'fontFamily': 'Inter, sans-serif',
  'fontSize': '22px',
  'edgeLabelBackground': '#0a0a0a',
  'clusterBkg': '#12122a',
  'clusterBorder': '#c9a227'
